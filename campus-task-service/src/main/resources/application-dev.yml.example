# 开发环境配置模板
# 使用方法: 复制此文件为 application-dev.yml，或通过环境变量注入敏感信息
# cp application-dev.yml.example application-dev.yml
spring:
  cloud:
    nacos:
      discovery:
        server-addr: "${NACOS_ADDR:localhost:8848}"
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: "${DB_URL:jdbc:mysql://localhost:3306/campus_task?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true}"
    username: "${DB_USERNAME:root}"
    password: "${DB_PASSWORD:your_db_password}"

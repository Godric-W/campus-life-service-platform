# 本地开发环境配置模板
# 使用方法: 复制此文件为 application-local.yml，填入真实值
# cp application-local.yml.example application-local.yml
spring:
  cloud:
    nacos:
      discovery:
        server-addr: localhost:8848
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/campus_user?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
    username: root
    password: "your_db_password"

campus:
  security:
    jwt-secret: your-jwt-secret-key
